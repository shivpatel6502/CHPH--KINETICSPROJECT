# Copy to .env — never commit .env to git
NODE_ENV=development
PORT=3001

# Database (PostgreSQL on RDS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wbb_dashboard
DB_USER=wbb_admin
DB_PASSWORD=changeme

# AWS
AWS_REGION=us-east-1
AWS_SECRET_NAME=wbb-dashboard/anthropic-api-key

# For local dev only — in prod the key comes from Secrets Manager
ANTHROPIC_API_KEY=sk-ant-...

# AI Cache TTL in seconds (12 hours default)
AI_CACHE_TTL=43200

# CORS — set to your CloudFront domain in prod
CORS_ORIGIN=http://localhost:3000
